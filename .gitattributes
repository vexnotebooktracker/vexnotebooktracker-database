# Default: text files normalized to LF in the repo
* text=auto eol=lf

# SQL and schema files
*.sql       text eol=lf
*.ddl       text eol=lf
*.dml       text eol=lf

# Common formats
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
*.csv       text eol=lf
*.sh        text eol=lf

# Windows scripts must be CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binaries
*.bak       binary
*.dmp       binary
*.zip       binary
*.tar.gz    binary
*.png       binary
*.pdf       binary
